using system;
string nombre;
int edad;
float peso;
float estatura;
bool seguro;

static void main()
{
    console.WriteLine("Ingrese su nombre:");
    console.ReadLine(nombre);
    console.WriteLine("Ingrese su edad:");
    int.Parse(console.ReadLine(edad));
    console.WriteLine("Ingrese su peso(Kg):");
    float.Parse(console.ReadLine(peso));
    console.WriteLine("Ingrese su estatura(m):");
    float.Parse(console.ReadLine(estatura));
    console.WriteLine("¿Tiene seguro?(s/n):");
    bool.Parse(console.ReadLine(seguro));
}
